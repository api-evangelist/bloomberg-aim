          "@id": "bloomberg:basketName",
          "@type": "xsd:string"
        },
        "notes": {
          "@id": "bloomberg:notes",
          "@type": "xsd:string"
        },
        "createdDate": {
          "@id": "schema:dateCreated",
          "@type": "xsd:date"
        },
        "lastUpdated": {
          "@id": "schema:dateModified",
          "@type": "xsd:dateTime"
        },
        "routes": {
          "@id": "bloomberg:routes",
          "@type": "@id",
          "@container": "@set"
        }
      }
