        },
        "averagePrice": {
          "@id": "bloomberg:averagePrice",
          "@type": "xsd:decimal"
        },
        "broker": {
          "@id": "bloomberg:broker",
          "@type": "xsd:string"
        },
        "orderType": {
          "@id": "bloomberg:orderType",
          "@type": "xsd:string"
        },
        "limitPrice": {
          "@id": "bloomberg:limitPrice",
          "@type": "xsd:decimal"
        },
        "strategy": {
          "@id": "bloomberg:strategy",
          "@type": "xsd:string"
        },
        "status": {
          "@id": "bloomberg:status",
          "@type": "xsd:string"
        },
        "exchange": {
          "@id": "schema:Exchange",
          "@type": "xsd:string"
        },
        "commission": {
          "@id": "bloomberg:commission",
