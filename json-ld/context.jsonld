          "@type": "xsd:date"
        },
        "lastUpdated": {
          "@id": "schema:dateModified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Trade": {
      "@id": "bloomberg:Trade",
      "@context": {
        "sequenceNumber": {
          "@id": "bloomberg:sequenceNumber",
