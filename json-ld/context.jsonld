          "@id": "bloomberg:weight",
          "@type": "xsd:decimal"
        },
        "unrealizedPnL": {
          "@id": "bloomberg:unrealizedPnL",
          "@type": "xsd:decimal"
        },
        "realizedPnL": {
          "@id": "bloomberg:realizedPnL",
          "@type": "xsd:decimal"
        },
        "sector": {
          "@id": "bloomberg:sector",
          "@type": "xsd:string"
        },
        "country": {
          "@id": "schema:countryOfOrigin",
          "@type": "xsd:string"
        },
        "tradeDate": {
