{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trigger",
  "type": "object",
  "properties": {
    "@type": {
      "type": "string"
    },
    "identifier": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "frequency": {
      "type": "string"
    },
    "snapshotTime": {
      "type": "string",
      "description": "Time of day for the snapshot (HH:MM)"
    },
    "timezone": {
      "type": "string",
      "description": "Timezone for the trigger schedule"
    }
  }
}